NODE_ENV=development
PORT=3000
DB_HOST=localhost
DB_PORT=5432

# Переменные ниже должны быть указаны в GitHub Secrets для продакшена:
#   DB_USER, DB_PASSWORD, JWT_SECRET, ADMIN_EMAIL, ADMIN_PASSWORD
DB_NAME=boards
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin

# Time span after which the token expires, added as the exp claim in the payload.
# It is expressed in seconds or a string describing a time span (E.g.: 60, "2 days", "10h", "7d").
# A numeric value is interpreted as a seconds count. If you use a string be sure you provide the time units (days, hours, etc.),
# otherwise milliseconds unit is used by default ("120" is equal to "120ms"). This will override any existing value in the claim.
# DEFAULT: 15m
JWT_LIFETIME=15m